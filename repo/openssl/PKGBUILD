# gpkg PKGBUILD for openssl
# POSIX shell compliant - EE Ethos

pkgname="openssl"
pkgver="3.4.5"
pkgdesc="A robust, commercial-grade, full-featured toolkit for TLS and SSL"
url="https://www.openssl.org/"
source="https://www.openssl.org/source/openssl-$pkgver.tar.gz"

# Tools to be used (no GNU assumptions)
CC="clang"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "openssl-$pkgver"
    
    ./Configure --prefix=/usr \
                --openssldir=/etc/ssl \
                shared \
                no-tests \
                linux-x86_64 \
                CC=$CC
    
    bmake
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "openssl-$pkgver"
    bmake DESTDIR="$DESTDIR" install_sw
}

