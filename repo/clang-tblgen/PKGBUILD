# gpkg PKGBUILD for clang-tblgen
# POSIX shell compliant - EE Ethos

pkgname="clang-tblgen"
pkgver="18.1.8"
pkgdesc="Clang TableGen tool"
url="https://clang.llvm.org/"
source="https://github.com/llvm/llvm-project/releases/download/llvmorg-$pkgver/clang-$pkgver.src.tar.xz;https://github.com/llvm/llvm-project/releases/download/llvmorg-$pkgver/llvm-$pkgver.src.tar.xz"

# Tools to be used (no GNU assumptions)
CC="clang"
CXX="clang++"

build() {
    echo "Building $pkgname-$pkgver..."
    # Note: clang-tblgen requires LLVM headers/libraries to build.
    # This usually happens within a full clang build or with LLVM installed.
    cd "clang-$pkgver.src"
    
    cmake -G Ninja -B build \
          -DCMAKE_C_COMPILER=$CC \
          -DCMAKE_CXX_COMPILER=$CXX \
          -DCMAKE_BUILD_TYPE=Release \
          -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_MAKE_PROGRAM=samu \
          -DCLANG_TOOL_CLANG_TBLGEN_BUILD=ON
    
    samu clang-tblgen
}

package() {
    echo "Installing $pkgname into $DESTDIR/usr/bin"
    mkdir -p "$DESTDIR/usr/bin"
    cd "clang-$pkgver.src"
    cp build/bin/clang-tblgen "$DESTDIR/usr/bin/"
}

