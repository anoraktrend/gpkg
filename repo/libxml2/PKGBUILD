# gpkg PKGBUILD for libxml2
# POSIX shell compliant - EE Ethos

pkgname="libxml2"
pkgver="2.15.2"
pkgdesc="XML parsing library, version 2"
url="https://gitlab.gnome.org/GNOME/libxml2"
source="https://download.gnome.org/sources/libxml2/${pkgver%.*}/libxml2-$pkgver.tar.xz"

# Tools to be used (no GNU assumptions)
CC="clang"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "libxml2-$pkgver"
    
    ./configure --prefix=/usr \
                --disable-dependency-tracking \
                --without-python \
                --without-icu \
                --without-lzma \
                CC=$CC
    bmake
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "libxml2-$pkgver"
    bmake DESTDIR="$DESTDIR" install
}

