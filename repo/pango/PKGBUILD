# gpkg PKGBUILD for pango
# POSIX shell compliant - EE Ethos

pkgname="pango"
pkgver="1.57.1"
pkgdesc="A library for layout and rendering of text"
url="https://pango.gnome.org/"
source="https://download.gnome.org/sources/pango/${pkgver%.*}/pango-$pkgver.tar.xz"

# Tools to be used (no GNU assumptions)
CC="clang"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "pango-$pkgver"
    
    # Pango uses Meson
    meson setup build \
          --prefix=/usr \
          --buildtype=release \
          -Dintrospection=disabled \
          --backend=ninja
    
    samu -C build
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "pango-$pkgver"
    DESTDIR="$DESTDIR" samu -C build install
}

