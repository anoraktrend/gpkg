# gpkg PKGBUILD for llvm-tblgen
# POSIX shell compliant - EE Ethos

pkgname="llvm-tblgen"
pkgver="18.1.8"
pkgdesc="LLVM TableGen tool"
url="https://llvm.org/"
source="https://github.com/llvm/llvm-project/releases/download/llvmorg-$pkgver/llvm-$pkgver.src.tar.xz"

# Tools to be used (no GNU assumptions)
CC="clang"
CXX="clang++"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "llvm-$pkgver.src"
    
    cmake -G Ninja -B build \
          -DCMAKE_C_COMPILER=$CC \
          -DCMAKE_CXX_COMPILER=$CXX \
          -DCMAKE_BUILD_TYPE=Release \
          -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_MAKE_PROGRAM=samu \
          -DLLVM_BUILD_TOOLS=OFF \
          -DLLVM_BUILD_UTILS=ON \
          -DLLVM_TOOL_LLVM_TBLGEN_BUILD=ON
    
    samu llvm-tblgen
}

package() {
    echo "Installing $pkgname into $DESTDIR/usr/bin"
    mkdir -p "$DESTDIR/usr/bin"
    cd "llvm-$pkgver.src"
    cp build/bin/llvm-tblgen "$DESTDIR/usr/bin/"
}

