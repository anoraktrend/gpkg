# gpkg PKGBUILD for busybox
# POSIX shell compliant - EE Ethos

pkgname="busybox"
pkgver="1.37.0"
pkgdesc="Swiss Army Knife of embedded Linux utilities"
url="https://busybox.net/"
source="https://busybox.net/downloads/busybox-$pkgver.tar.bz2"

# Tools to be used (no GNU assumptions)
CC="clang"

build() {
    echo "Building $pkgname-$pkgver with $CC..."
    cd "busybox-$pkgver"
    # User steering: use gmake for GNU-dependent builds
    gmake CC=$CC HOSTCC=$CC defconfig
    sed -i 's/CONFIG_TC=y/CONFIG_TC=n/' .config
    gmake CC=$CC HOSTCC=$CC
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "busybox-$pkgver"
    gmake CC=$CC HOSTCC=$CC CONFIG_PREFIX="$DESTDIR" install
}
