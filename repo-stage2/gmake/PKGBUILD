# gpkg PKGBUILD for gmake
# POSIX shell compliant - EE Ethos
# Note: Allowed as an exception for GNU-dependent builds (like Git).

pkgname="gmake"
pkgver="4.4.1"
pkgdesc="GNU Make"
url="https://www.gnu.org/software/make/"
source="https://ftp.gnu.org/gnu/make/make-$pkgver.tar.gz"

# Tools to be used (no GNU assumptions for CC)
CC="clang"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "make-$pkgver"
    ./configure --prefix=/usr \
                --disable-nls \
                --program-prefix=g \
                CC=$CC
    # Use ckati to build gmake initially
    ckati
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "make-$pkgver"
    ckati DESTDIR="$DESTDIR" install
}

