# gpkg PKGBUILD for musl libc (Stage2)
# Use 'ckati' to build musl

pkgname="musl"
pkgver="1.2.6"
pkgdesc="The lightweight C standard library"
url="https://musl.libc.org/"
source="https://musl.libc.org/releases/musl-$pkgver.tar.gz"

# Use system compilers
CC="clang"

build() {
    echo "Building $pkgname-$pkgver using stage1 tools..."
    cd "musl-$pkgver"
    ./configure --prefix=/usr --syslibdir=/lib
    ckati
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "musl-$pkgver"
    ckati DESTDIR="$DESTDIR" install
    # Ensure relative symlink for loader
    mkdir -p "$DESTDIR/lib"
    ln -sf ../usr/lib/libc.so "$DESTDIR/lib/ld-musl-x86_64.so.1"
}
