# gpkg PKGBUILD for llvm (Stage1)
# Use system tools to build the LLVM stack

pkgname="llvm"
pkgver="22.1.3"
pkgdesc="LLVM compiler infrastructure and backend"
url="https://llvm.org/"
source="https://github.com/llvm/llvm-project/releases/download/llvmorg-$pkgver/llvm-project-$pkgver.src.tar.xz"

# Use system compilers
CC="clang"
CXX="clang++"
build() {
    echo "Building the entire LLVM stack $pkgver..."
    cd "llvm-project-$pkgver.src"

    # Decisively disable benchmarks by removing them from the build system
    find . -name CMakeLists.txt -exec sed -i 's/add_subdirectory(benchmark)/#add_subdirectory(benchmark)/g' {} +
    find . -name CMakeLists.txt -exec sed -i 's/add_subdirectory(benchmarks)/#add_subdirectory(benchmarks)/g' {} +

    cmake -G Ninja -S llvm -B build \

    # We build everything from the monorepo root
    cmake -G Ninja -S llvm -B build \
          -DCMAKE_C_COMPILER=$CC \
          -DCMAKE_CXX_COMPILER=$CXX \
          -DCMAKE_CXX_FLAGS="-Wno-error=c2y-extensions" \
          -DCMAKE_BUILD_TYPE=Release \
          -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_MAKE_PROGRAM=samu \
          -DLLVM_ENABLE_PROJECTS="clang;lld" \
          -DLLVM_ENABLE_RUNTIMES="compiler-rt;libcxx;libcxxabi;libunwind" \
          -DLLVM_TARGETS_TO_BUILD="X86;ARM;AArch64" \
          -DLLVM_INCLUDE_TESTS=OFF \
          -DLLVM_BUILD_BENCHMARKS=OFF \
          -DCLANG_INCLUDE_TESTS=OFF \
          -DLIBCXX_INCLUDE_TESTS=OFF
    
    samu -C build
}

package() {
    echo "Installing LLVM stack into $DESTDIR..."
    cd "llvm-project-$pkgver.src"
    DESTDIR="$DESTDIR" samu -C build install
}
