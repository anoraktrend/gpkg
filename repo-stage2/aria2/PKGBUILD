# gpkg PKGBUILD for aria2 (Stage1)
# Use system tools to build aria2

pkgname="aria2"
pkgver="1.37.0"
pkgdesc="A high-performance download utility"
url="https://aria2.github.io/"
source="https://github.com/aria2/aria2/releases/download/release-$pkgver/aria2-$pkgver.tar.xz"

# Use system compilers
CC="clang"
CXX="clang++"

build() {
    echo "Building $pkgname-$pkgver using system tools..."
    cd "aria2-$pkgver"
    
    # aria2 uses Autotools (configure/bmake)
    ./configure --prefix=/usr \
                --disable-nls \
                --disable-dependency-tracking \
                --without-libxml2 \
                --with-expat \
                --without-sqlite3
    
    # Use host bmake
    bmake
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "aria2-$pkgver"
    bmake DESTDIR="$DESTDIR" install
}
