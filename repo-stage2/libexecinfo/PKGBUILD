# gpkg PKGBUILD for libexecinfo
# POSIX shell compliant - EE Ethos
# BSD-licensed backtrace(3) implementation for musl

pkgname="libexecinfo"
pkgver="1.1"
pkgdesc="A quick-n-dirty BSD licensed clone of backtrace facility"
url="https://github.com/sjnam/libexecinfo"
source="https://github.com/sjnam/libexecinfo/archive/v$pkgver.tar.gz"

# Tools to be used (no GNU assumptions)
CC="clang"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "libexecinfo-$pkgver"
    # Simple build logic
    $CC $CFLAGS -c execinfo.c -o execinfo.o
    $CC $CFLAGS -c stacktraverse.c -o stacktraverse.o
    llvm-ar rcs libexecinfo.a execinfo.o stacktraverse.o
    $CC -shared $LDFLAGS -o libexecinfo.so.1 execinfo.o stacktraverse.o
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "libexecinfo-$pkgver"
    mkdir -p "$DESTDIR/usr/include"
    mkdir -p "$DESTDIR/usr/lib"
    cp execinfo.h "$DESTDIR/usr/include/"
    cp libexecinfo.a "$DESTDIR/usr/lib/"
    cp libexecinfo.so.1 "$DESTDIR/usr/lib/"
    ln -sf libexecinfo.so.1 "$DESTDIR/usr/lib/libexecinfo.so"
}
