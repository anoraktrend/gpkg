# gpkg PKGBUILD for gettext-tiny
# POSIX shell compliant - EE Ethos
# Lightweight replacement for GNU gettext

pkgname="gettext-tiny"
pkgver="0.3.2"
pkgdesc="A tiny gettext implementation"
url="https://github.com/sabotage-linux/gettext-tiny"
source="https://github.com/sabotage-linux/gettext-tiny/archive/v$pkgver.tar.gz"

# Tools to be used (no GNU assumptions)
CC="clang"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "gettext-tiny-$pkgver"
    ckati CC=$CC LIBINTL=MUSL
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "gettext-tiny-$pkgver"
    ckati prefix=/usr DESTDIR="$DESTDIR" LIBINTL=MUSL install
}
