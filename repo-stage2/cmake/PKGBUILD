# gpkg PKGBUILD for cmake (Stage1)
# Use system tools to build CMake

pkgname="cmake"
pkgver="4.3.1"
pkggdesc="A cross-platform, open-source build system generator"
url="https://cmake.org/"
source="https://github.com/Kitware/CMake/releases/download/v$pkgver/cmake-$pkgver.tar.gz"

# Use system compilers
CC="clang"
CXX="clang++"

build() {
    echo "Bootstrapping $pkgname-$pkgver with $CC..."
    cd "cmake-$pkgver"
    
    # Fix missing stdint.h in some environments
    find . -name "network.h" -exec sed -i '16i #include <stdint.h>' {} +

    # Using CMake's own bootstrap script
    ./bootstrap --prefix=/usr \
                --parallel=$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1) \
                --generator=Ninja \
                -- \
                -DCMAKE_C_COMPILER=$CC \
                -DCMAKE_CXX_COMPILER=$CXX \
                -DCMAKE_MAKE_PROGRAM=samu \
                -DBUILD_CursesDialog=OFF \
                -DCMake_INSTALL_DEPENDENCIES=OFF
    
    samu
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "cmake-$pkgver"
    DESTDIR="$DESTDIR" samu install
}

