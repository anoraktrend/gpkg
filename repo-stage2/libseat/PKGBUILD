# gpkg PKGBUILD for libseat
# POSIX shell compliant - EE Ethos

pkgname="libseat"
pkgver="0.9.3"
pkgdesc="A universal seat management library"
url="https://sr.ht/~kennylevinsen/seatd/"
source="https://git.sr.ht/~kennylevinsen/seatd/archive/$pkgver.tar.gz"

# Tools to be used (no GNU assumptions)
CC="clang"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "seatd-$pkgver"
    
    # libseat is part of seatd, we build it with Meson
    meson setup build \
          --prefix=/usr \
          --buildtype=release \
          -Dlibseat-builtin=enabled \
          -Dlibseat-logind=systemd \
          -Dserver=enabled \
          --backend=ninja
    
    samu -C build
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "seatd-$pkgver"
    DESTDIR="$DESTDIR" samu -C build install
}
