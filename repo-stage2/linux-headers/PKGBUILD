# gpkg PKGBUILD for linux-headers
# POSIX shell compliant - EE Ethos

pkgname="linux-headers"
pkgver="6.19.12"
pkgdesc="API headers required for userspace programs to communicate with the Linux kernel"
url="https://www.kernel.org/"
source="https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-$pkgver.tar.xz"

# Tools to be used (no GNU assumptions)
CC="clang"

build() {
    echo "Preparing Linux kernel headers $pkgver..."
    cd "linux-$pkgver"
    # Use a LOCAL relative path within the build dir to avoid permissions errors
    rm -rf staged_dest
    mkdir -p staged_dest
    # Use LLVM=1 for kernel stuff
    gmake LLVM=1 ARCH=x86_64 HOSTCC=$CC CC=$CC headers_install INSTALL_HDR_PATH="$(pwd)/staged_dest"
}

package() {
    echo "Installing headers from staged_dest into $DESTDIR/usr"
    mkdir -p "$DESTDIR/usr"
    # The kernel install puts them in staged_dest/include
    cp -r "linux-$pkgver/staged_dest/include" "$DESTDIR/usr/"
}
