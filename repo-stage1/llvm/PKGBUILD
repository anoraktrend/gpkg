# gpkg PKGBUILD for llvm
# POSIX shell compliant - EE Ethos

pkgname="llvm"
pkgver="18.1.8"
pkgdesc="LLVM compiler infrastructure and backend"
url="https://llvm.org/"
source="https://github.com/llvm/llvm-project/releases/download/llvmorg-$pkgver/llvm-$pkgver.src.tar.xz"

# Tools to be used (no GNU assumptions)
CC="clang"
CXX="clang++"

build() {
    echo "Building $pkgname-$pkgver..."
    cd "llvm-$pkgver.src"
    
    cmake -G Ninja -B build \
          -DCMAKE_C_COMPILER=$CC \
          -DCMAKE_CXX_COMPILER=$CXX \
          -DCMAKE_BUILD_TYPE=Release \
          -DCMAKE_INSTALL_PREFIX=/usr \
          -DCMAKE_MAKE_PROGRAM=samu \
          -DLLVM_BUILD_TOOLS=ON \
          -DLLVM_INSTALL_UTILS=ON \
          -DLLVM_TARGETS_TO_BUILD="X86;ARM;AArch64" \
          -DLLVM_ENABLE_PROJECTS="clang;lld" \
          -DLLVM_ENABLE_RUNTIMES="compiler-rt;libcxx;libcxxabi;libunwind"
    
    samu -C build
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "llvm-$pkgver.src"
    DESTDIR="$DESTDIR" Samu -C build install
}
