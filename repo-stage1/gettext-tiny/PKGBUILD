# gpkg PKGBUILD for gettext-tiny (Stage1)
# Use system 'make' to build gettext-tiny

pkgname="gettext-tiny"
pkgver="0.3.2"
pkgdesc="A tiny gettext implementation"
url="https://github.com/sabotage-linux/gettext-tiny"
source="https://github.com/sabotage-linux/gettext-tiny/archive/v$pkgver.tar.gz"

# Use system compilers
CC="clang"

build() {
    echo "Building $pkgname-$pkgver using system tools..."
    cd "gettext-tiny-$pkgver"
    /usr/bin/make CC=$CC LIBINTL=MUSL
}

package() {
    echo "Installing $pkgname into $DESTDIR..."
    cd "gettext-tiny-$pkgver"
    /usr/bin/make prefix=/usr DESTDIR="$DESTDIR" LIBINTL=MUSL install
}
