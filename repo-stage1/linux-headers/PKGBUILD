# gpkg PKGBUILD for linux-headers (Stage1)
# Use system 'make' to build kernel headers

pkgname="linux-headers"
pkgver="6.19.12"
pkgdesc="API headers required for userspace programs to communicate with the Linux kernel"
url="https://www.kernel.org/"
source="https://cdn.kernel.org/pub/linux/kernel/v6.x/linux-$pkgver.tar.xz"

# Use system compilers
CC="clang"

build() {
    echo "Preparing Linux kernel headers $pkgver using system make..."
    cd "linux-$pkgver"
    # Use a LOCAL relative path within the build dir
    rm -rf staged_dest
    mkdir -p staged_dest
    # Pass an absolute path but one that we own
    /usr/bin/make LLVM=1 ARCH=x86_64 HOSTCC=$CC CC=$CC headers_install INSTALL_HDR_PATH="$(pwd)/staged_dest"
}

package() {
    echo "Installing headers from staged_dest into $DESTDIR/usr"
    mkdir -p "$DESTDIR/usr"
    # The kernel install puts them in staged_dest/include
    cp -r "linux-$pkgver/staged_dest/include" "$DESTDIR/usr/"
}
